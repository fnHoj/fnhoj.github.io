{
    "compilerOptions": {
        "target": "esnext",
        "outDir": "./dist",
        "rootDir": "./source",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["source/**/*.ts"],
    "exclude": ["node_modules"]
}